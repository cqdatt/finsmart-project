<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee 
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>FinSmart - Personal Finance Management</display-name>

    <!-- Welcome File -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Session Configuration -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Error Pages -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/error/404.jsp</location>
    </error-page>

    <!-- Auth Filter - CHỈ FILTER CÁC PATH CẦN BẢO MẬT -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.finsmart.filter.AuthFilter</filter-class>
    </filter>
    
    <!-- ✅ CHỈ filter các path cần đăng nhập - KHÔNG CÓ /* -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/dashboard/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/transactions/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/categories/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/budgets/*</url-pattern>
    </filter-mapping>

</web-app>